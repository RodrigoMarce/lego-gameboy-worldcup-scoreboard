// Render the 32x32 ball into the sprite at 2x scale (64x64).
// Background is the chosen transparent colour so rotation corners blend in.
void drawBallSprite() {
  ball.fillSprite(TFT_TRANSPARENT);
  for (int row = 0; row < 32; row++) {
    for (int col = 0; col < 32; col++) {
      uint8_t px = BALL[row][col];
      uint16_t c;
      if      (px == 1) c = TFT_BLACK;
      else if (px == 2) c = GB_INK;
      else continue;
      // 2x: draw a 2x2 block
      ball.fillRect(col * 2, row * 2, 2, 2, c);
    }
  }
}

// ── Draw the hand-drawn net bitmap ───────────────────────────────────────────
// bulge isn't used for the bitmap net (kept for call-compatibility); on a goal
// we just flash the posts brighter instead.
void drawNet(bool bulge) {
  for (int y = 0; y < NET_H; y++) {
    for (int x = 0; x < NET_W; x++) {
      int idx = y * NET_W + x;
      int byteIdx = idx >> 2;            // 4 px per byte
      int shift   = (3 - (idx & 3)) * 2; // 2 bits per px
      uint8_t v = (NET_BMP[byteIdx] >> shift) & 0x03;
      if (v == 0) continue;             // transparent
      uint16_t c = (v == 2) ? GB_INK : GB_DIM2;
      tft.drawPixel(NET_DX + x, NET_DY + y, c);
    }
  }
}

// Render the net bitmap once into netSpr. Transparent pixels become GB_BG so the
// sprite can be pushed opaquely over the green pitch and blend seamlessly — one
// fast block transfer per frame instead of thousands of drawPixel calls.
void renderNetSprite() {
  netSpr.createSprite(NET_W, NET_H);
  netSpr.setColorDepth(16);
  netSpr.fillSprite(GB_BG);
  for (int y = 0; y < NET_H; y++) {
    for (int x = 0; x < NET_W; x++) {
      int idx = y * NET_W + x;
      uint8_t v = (NET_BMP[idx >> 2] >> ((3 - (idx & 3)) * 2)) & 0x03;
      if (v == 0) continue;
      netSpr.drawPixel(x, y, (v == 2) ? GB_INK : GB_DIM2);
    }
  }
}
// ── Goal animation ────────────────────────────────────────────────────────────
void playGoalAnimation(const char* scorerName) {
  // Act 1: ball arcs over a clean "pitch" (uniform bg so erases are seamless)
  tft.fillScreen(GB_BG);
  // simple pitch ground line across the lower third
  tft.drawFastHLine(0, SCR_H - 60, SCR_W, GB_DIM2);
  renderNetSprite();                 // build the net sprite once
  netSpr.pushSprite(NET_DX, NET_DY); // initial net draw

  ball.createSprite(64, 64);
  ball.setColorDepth(16);
  ball.setPivot(32, 32);            // rotate around the centre
  drawBallSprite();                 // render once; we just rotate it each step

  int   prevCx = arcX[0], prevCy = arcY[0];
  float angle  = 0;
  const int ERASE = 96;             // erase box big enough for a rotated 64x64

  for (int i = 0; i < ARC_STEPS; i++) {
    int cx = arcX[i] + 32;          // sprite centre x (arc stores top-left-ish)
    int cy = arcY[i] + 32;          // sprite centre y

    // Erase a generous square at the previous centre
    tft.fillRect(prevCx + 32 - ERASE/2, prevCy + 32 - ERASE/2,
                 ERASE, ERASE, GB_BG);
    // Redraw the pitch ground line where the erase box crossed it
    tft.drawFastHLine(prevCx + 32 - ERASE/2, SCR_H - 60, ERASE, GB_DIM2);
    // Redraw the net (fast sprite push) wherever the erase box reached it
    if (prevCx + 32 + ERASE/2 >= NET_DX) netSpr.pushSprite(NET_DX, NET_DY);

    // Draw the ball rotated about its pivot, centred at (cx, cy).
    // pushRotated places the sprite's pivot at the TFT's pivot point,
    // so set the TFT pivot to the desired centre first.
    tft.setPivot(cx, cy);
    ball.pushRotated(angle, TFT_TRANSPARENT);

    prevCx = arcX[i];
    prevCy = arcY[i];
    angle += 28;                     // spin ~28 deg per step
    delay(80);
  }

  ball.deleteSprite();

  // Act 2: net "shake" — quick erase + re-push to suggest the ball hitting it
  tft.fillRect(prevCx + 32 - ERASE/2, prevCy + 32 - ERASE/2, ERASE, ERASE, GB_BG);
  netSpr.pushSprite(NET_DX, NET_DY);     delay(80);
  netSpr.pushSprite(NET_DX + 2, NET_DY); delay(120);
  netSpr.pushSprite(NET_DX, NET_DY);     delay(80);
  netSpr.pushSprite(NET_DX + 2, NET_DY); delay(120);
  netSpr.deleteSprite();                 // free the ~18KB now that Act 1-2 are done

  // Screen flash
  tft.fillScreen(GB_INK);  delay(60);
  tft.fillScreen(GB_BG);   delay(40);
  tft.fillScreen(GB_INK);  delay(60);
  tft.fillScreen(GB_BG);   delay(40);

  // Act 3: GOAL! + scorer name pulses
  tft.fillScreen(GB_DARK);
  for (int pulse = 0; pulse < 3; pulse++) {
    tft.setTextDatum(MC_DATUM);
    tft.setTextColor(GB_INK, GB_DARK);
    tft.drawString("GOAL!", SCR_W / 2, SCR_H / 2 - 24, 7);
    tft.setTextColor(GB_DIM2, GB_DARK);
    tft.drawString(scorerName, SCR_W / 2, SCR_H / 2 + 40, 4);
    delay(420);

    tft.setTextColor(GB_DIM2, GB_DARK);
    tft.drawString("GOAL!", SCR_W / 2, SCR_H / 2 - 24, 7);
    tft.setTextColor(GB_INK, GB_DARK);
    tft.drawString(scorerName, SCR_W / 2, SCR_H / 2 + 40, 4);
    delay(420);
  }
  delay(600);
}

// ── Strip diacritics ──────────────────────────────────────────────────────────
void stripDiacritics(char* str) {
  unsigned char* s = (unsigned char*)str;
  unsigned char* d = s;
  while (*s) {
    if (s[0] == 0xC3 && s[1] != 0) {
      unsigned char b = s[1];
      char rep = '?';
      if      (b >= 0x80 && b <= 0x86) rep = 'A';
      else if (b == 0x87)               rep = 'C';
      else if (b >= 0x88 && b <= 0x8B) rep = 'E';
      else if (b >= 0x8C && b <= 0x8F) rep = 'I';
      else if (b == 0x90)               rep = 'D';
      else if (b == 0x91)               rep = 'N';
      else if (b >= 0x92 && b <= 0x96) rep = 'O';
      else if (b == 0x98)               rep = 'O';
      else if (b >= 0x99 && b <= 0x9C) rep = 'U';
      else if (b == 0x9D)               rep = 'Y';
      else if (b >= 0xA0 && b <= 0xA6) rep = 'a';
      else if (b == 0xA7)               rep = 'c';
      else if (b >= 0xA8 && b <= 0xAB) rep = 'e';
      else if (b >= 0xAC && b <= 0xAF) rep = 'i';
      else if (b == 0xB1)               rep = 'n';
      else if (b >= 0xB2 && b <= 0xB6) rep = 'o';
      else if (b == 0xB8)               rep = 'o';
      else if (b >= 0xB9 && b <= 0xBC) rep = 'u';
      else if (b == 0xBD || b == 0xFF)  rep = 'y';
      *d++ = (unsigned char)rep;
      s += 2;
    } else if (s[0] >= 0x80) {
      s++;
      while (*s >= 0x80 && *s < 0xC0) s++;
    } else {
      *d++ = *s++;
    }
  }
  *d = '\0';
}

// ── NTP ───────────────────────────────────────────────────────────────────────
void syncTime() {
  configTime(GMT_OFFSET_SEC, DST_OFFSET_SEC, "pool.ntp.org");
  struct tm timeinfo;
  int tries = 0;
  Serial.print("Syncing time");
  while (!getLocalTime(&timeinfo) && tries < 20) {
    delay(500);
    Serial.print(".");
    tries++;
  }
  if (getLocalTime(&timeinfo)) {
    Serial.println(" OK");
    char buf[32];
    strftime(buf, sizeof(buf), "%Y-%m-%d %H:%M:%S", &timeinfo);
    Serial.print("Current time: ");
    Serial.println(buf);
  } else {
    Serial.println(" FAILED");
  }
}

