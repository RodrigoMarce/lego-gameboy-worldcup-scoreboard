/*
  LEGO Game Boy -- World Cup live scoreboard  v5
  ------------------------------------------------------------
  Brain   : ESP32 (WROOM-32 dev board with Wi-Fi)
  Display : 2.4" ILI9341 240x320 SPI panel, landscape (320x240)
  Data    : ESPN's public (unofficial) World Cup scoreboard JSON

  Libraries: TFT_eSPI by Bodmer, ArduinoJson by Benoit Blanchon (v6.x)
  Board:     esp32 by Espressif
*/

#include <WiFi.h>
#include <HTTPClient.h>
#define ARDUINOJSON_DEFAULT_NESTING_LIMIT 15
#include <ArduinoJson.h>
#include <TFT_eSPI.h>
#include <time.h>
#include "config.h"   // copy config.h.example -> config.h and fill in your Wi-Fi + timezone

// ---------------- user settings ----------------
// Wi-Fi credentials and timezone now live in config.h (gitignored, kept private).
// See config.h.example for the template.

const uint32_t FETCH_EVERY_MS  = 60000;
const uint32_t ROTATE_EVERY_MS = 5000;

// Set to true to fire the goal animation once on boot for testing.
// Change to false when you're happy with how it looks.
#define TEST_ANIMATION false
// ------------------------------------------------

// Game Boy DMG palette — RGB565
#define GB_BG    0x09C1   // #0f380f  background
#define GB_DARK  0x1183   // #0a2a0a  panel background
#define GB_DIM2  0x4C87   // #4a8a38  secondary text
#define GB_INK   0x9DE1   // #9bbc0f  primary text / scores

// Screen dimensions (landscape)
#define SCR_W 320
#define SCR_H 240

// Layout constants
#define HDR_H    24
#define PANEL_Y  26
#define PANEL_H  114
#define SCORER_Y 142
#define SCORER_H 72
#define FOOTER_Y 216
#define FOOTER_H 24

