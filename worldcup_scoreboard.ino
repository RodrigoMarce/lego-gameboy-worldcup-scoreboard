// ── Arc path precomputed ──────────────────────────────────────────────────────
#define ARC_STEPS 28
static int16_t arcX[ARC_STEPS];
static int16_t arcY[ARC_STEPS];

void precomputeArc() {
  float x0 = 4,   y0 = SCR_H / 2 + 20;   // start: far left, lower
  float x1 = NET_DX + 18, y1 = NET_DY + 30;   // land inside the goal mouth
  float peak = 80.0f;
  for (int i = 0; i < ARC_STEPS; i++) {
    float t  = (float)i / (ARC_STEPS - 1);
    arcX[i] = (int16_t)(x0 + t * (x1 - x0));
    arcY[i] = (int16_t)(y0 + (y1 - y0) * t - peak * 4.0f * t * (1.0f - t));
  }
}

